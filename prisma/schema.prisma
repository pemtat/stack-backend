generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  password     String
  fullName     String?
  phoneNumber  String?
  profileImage String?
  role         UserRole     @default(ADMIN)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  devices      UserDevice[]

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  imageUrl String?
  products Product[]

  @@map("categories")
}

model Product {
  id          Int       @id @default(autoincrement())
  productCode String    @unique
  name        String
  price       Float     @default(0)
  stock       Int       @default(0)
  unit        String
  imageUrl    String?
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([name])
  @@index([productCode])
  @@index([createdAt])
  @@map("products")
}

model AppVersion {
  id           Int      @id @default(autoincrement())
  platform     String   @unique // "ios" or "android"
  version      String
  buildNumber  Int
  forceUpdate  Boolean  @default(false)
  releaseNotes String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("app_versions")
}

model UserDevice {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String   // "ios" or "android"
  appVersion   String?
  buildNumber  Int?
  deviceModel  String?
  pushToken    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, platform])
  @@index([userId])
  @@map("user_devices")
}
