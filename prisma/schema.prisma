generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  fullName    String?
  phoneNumber String?
  role        UserRole @default(ADMIN)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  imageUrl String?
  products Product[]

  @@map("categories")
}

model Product {
  id          Int       @id @default(autoincrement())
  productCode String    @unique
  name        String
  price       Float     @default(0)
  stock       Int       @default(0)
  unit        String
  imageUrl    String?
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([name])
  @@index([productCode])
  @@index([createdAt])
  @@map("products")
}
